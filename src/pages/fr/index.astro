---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { t } from '../../i18n/utils';
import { projects, homepageFeaturedProjectIds } from '../../data/projects';
import type { Project } from '../../data/projects';

const lang = 'fr';
const tr = t(lang);
const featuredProjects = homepageFeaturedProjectIds
  .map((id) => projects.find((p) => p.id === id))
  .filter((p): p is Project => p !== undefined);
---

<BaseLayout lang={lang}>
  <!-- HERO -->
  <Hero lang={lang} />

  <!-- EN BREF -->
  <section class="section">
    <p class="label gsap-reveal" style="margin-bottom:1rem">{tr.brief.title}</p>
    <div class="brief-grid gsap-stagger">
      {tr.brief.items.map(item => (
        <div class="brief-card gsap-item">
          <span class="brief-num">{item.num}</span>
          <div class="brief-body">
            <h3 class="brief-title">{item.title}</h3>
            <p class="brief-desc">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- EXPERTISE -->
  <div class="expertise-wrapper">
  <section class="section expertise-section">
    <div class="section-header gsap-reveal">
      <p class="label">{tr.expertise.subtitle}</p>
      <h2 class="section-title">{tr.expertise.title}</h2>
    </div>
    <div class="expertise-grid gsap-stagger">
      {tr.expertise.items.map(item => (
        <div class="expertise-card gsap-item">
          <div class="expertise-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              {item.icon === 'shield' && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></>}
              {item.icon === 'code' && <><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></>}
              {item.icon === 'cloud' && <><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></>}
              {item.icon === 'shopping-bag' && <><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></>}
              {item.icon === 'brain' && <><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 4.44-1.14"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-4.44-1.14"/></>}
              {item.icon === 'mic' && <><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></>}
            </svg>
          </div>
          <h3 class="expertise-title">{item.title}</h3>
          <p class="expertise-desc">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  </div>

  <!-- PROJETS PHARES -->
  <section class="section">
    <div class="section-header gsap-reveal">
      <p class="label">{tr.projects_section.subtitle}</p>
      <h2 class="section-title">{tr.projects_section.title}</h2>
    </div>

    <div class="featured-projects">
      {featuredProjects.map((project, i) => (
        <div class={`featured-project gsap-reveal ${i % 2 === 1 ? 'featured-project--reverse' : ''}`}>
          <!-- Image -->
          <div class="fp-image gsap-clip">
            {project.image ? (
              <img
                src={project.image}
                alt={`Screenshot de ${project.title}`}
                loading="lazy"
                width="800"
                height="500"
              />
            ) : (
              <div class="fp-placeholder">
                <span class="mono fp-placeholder-title">{project.title}</span>
                <!-- TODO: remplacer par screenshot réel -->
              </div>
            )}
          </div>
          <!-- Content -->
          <div class="fp-content">
            <span class="label">{project.category}</span>
            <h3 class="fp-title">{lang === 'fr' ? project.title : project.titleEn}</h3>
            <p class="fp-desc">{lang === 'fr' ? project.description : project.descriptionEn}</p>
            <div class="fp-stack">
              {project.stack.slice(0, 4).map(tech => (
                <span class="tech-badge mono">{tech}</span>
              ))}
            </div>
            <div class="fp-links">
              {project.github && !project.repoEmpty && (
                <a href={project.github} class="btn-cyber" target="_blank" rel="noopener noreferrer">
                  {tr.projects_section.cta_code}
                </a>
              )}
              {project.demo && (
                <a href={project.demo} class="btn-primary" target="_blank" rel="noopener noreferrer">
                  {tr.projects_section.cta_demo} ↗
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="section-cta gsap-reveal">
      <a href="/fr/projects" class="btn-primary">
        {tr.projects_section.cta_all}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- CITATION -->
  <section class="quote-section gsap-reveal" aria-label="Citation">
    <div class="quote-inner">
      <div class="quote-bar" aria-hidden="true"></div>
      <blockquote class="quote-text">
        "{tr.quote.text}"
      </blockquote>
      <cite class="quote-author">
        — {tr.quote.author}, <em>{tr.quote.work}</em>
      </cite>
    </div>
  </section>
</BaseLayout>

<style>
  /* Brief section */
  .brief-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    border: 1px solid var(--border-subtle);
    margin-top: 2rem;
  }

  .brief-card {
    background: var(--bg-secondary);
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background 0.3s ease;
    border-right: 1px solid var(--border-subtle);
  }

  .brief-card:last-child {
    border-right: none;
  }

  .brief-card:hover {
    background: var(--bg-elevated);
  }

  .brief-num {
    font-family: var(--font-serif);
    font-size: 3rem;
    color: var(--accent-gold);
    opacity: 0.4;
    line-height: 1;
    font-style: italic;
  }

  .brief-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-style: normal;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .brief-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Expertise */
  .expertise-wrapper {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .expertise-section {
    background: transparent;
  }

  .section-header {
    margin-bottom: 3rem;
  }

  .section-header .label {
    margin-bottom: 0.75rem;
    display: block;
  }

  .section-title {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-style: normal;
  }

  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    border: 1px solid var(--border-subtle);
  }

  .expertise-card {
    background: var(--bg-primary);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border-right: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
    transition: background 0.3s ease, border-color 0.3s ease;
    cursor: default;
  }

  .expertise-card:hover {
    background: var(--bg-elevated);
    border-color: var(--accent-gold);
    transform: translateY(-4px);
  }

  .expertise-icon {
    color: var(--accent-gold);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-subtle);
    transition: border-color 0.3s ease;
  }

  .expertise-card:hover .expertise-icon {
    border-color: var(--accent-gold);
  }

  .expertise-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-style: normal;
    color: var(--text-primary);
  }

  .expertise-desc {
    font-size: 0.875rem;
    line-height: 1.6;
  }

  /* Featured projects */
  .featured-projects {
    display: flex;
    flex-direction: column;
    gap: 6rem;
    margin-top: 3rem;
  }

  .featured-project {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .featured-project--reverse {
    direction: rtl;
  }

  .featured-project--reverse > * {
    direction: ltr;
  }

  .fp-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
  }

  .fp-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .fp-placeholder {
    width: 100%;
    height: 100%;
    min-height: 300px;
    background: linear-gradient(135deg, var(--bg-secondary), var(--bg-elevated));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fp-placeholder-title {
    font-size: 1.2rem;
    color: var(--text-secondary);
    opacity: 0.3;
  }

  .fp-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .fp-title {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-style: normal;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .fp-desc {
    font-size: 0.9375rem;
    line-height: 1.75;
  }

  .fp-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-badge {
    font-size: 0.65rem;
    color: var(--accent-cyber);
    background: rgba(0, 229, 160, 0.08);
    border: 1px solid rgba(0, 229, 160, 0.2);
    padding: 0.25rem 0.6rem;
  }

  .fp-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .section-cta {
    margin-top: 4rem;
    text-align: center;
  }

  /* Quote */
  .quote-section {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
    padding: clamp(4rem, 8vw, 8rem) clamp(1.5rem, 10vw, 12rem);
  }

  .quote-inner {
    max-width: 900px;
    margin: 0 auto;
    padding-left: 2rem;
    border-left: 3px solid var(--accent-gold);
    position: relative;
  }

  .quote-bar {
    display: none;
  }

  .quote-text {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-style: italic;
    color: var(--text-primary);
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }

  .quote-author {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--text-secondary);
    font-style: normal;
    letter-spacing: 0.05em;
  }

  .quote-author em {
    color: var(--accent-gold);
    font-style: italic;
  }

  @media (max-width: 1024px) {
    .brief-grid {
      grid-template-columns: 1fr;
    }

    .brief-card {
      border-right: none;
      border-bottom: 1px solid var(--border-subtle);
    }

    .expertise-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .featured-project {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .featured-project--reverse {
      direction: ltr;
    }
  }

  @media (max-width: 640px) {
    .expertise-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
