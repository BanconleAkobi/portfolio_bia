---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TimelineItem from '../../components/TimelineItem.astro';
import { t } from '../../i18n/utils';

const lang = 'en';
const tr = t(lang);
const about = tr.about;
---

<BaseLayout lang={lang} title={about.title} description="Banconlé AKOBI — 4th-year INSA HdF engineer, IT Manager, founder of LanceOS.">
  <div class="page-hero">
    <div class="page-hero-inner">
      <p class="label gsap-reveal" style="margin-bottom:1rem">{about.subtitle}</p>
      <h1 class="page-title gsap-reveal">{about.title}</h1>
    </div>
  </div>

  <section class="section bio-section">
    <div class="bio-grid">
      <div class="bio-photo gsap-clip">
        <div class="photo-container">
          <img src="/images/profile.jpg" alt="Photo of Banconlé AKOBI" width="500" height="600" loading="eager" class="profile-img"
            onerror="this.parentElement.innerHTML='<div class=\'photo-placeholder\'><span class=\'mono\'>B.A</span></div>'" />
        </div>
      </div>
      <div class="bio-text">
        <p class="label gsap-reveal" style="margin-bottom:1rem">{about.subtitle}</p>
        <h2 class="bio-heading gsap-reveal">Banconlé AKOBI</h2>
        <div class="bio-paragraphs">
          {about.bio.split('\n\n').map(para => (
            <p class="bio-para gsap-reveal">{para}</p>
          ))}
        </div>
        <div class="bio-links gsap-reveal">
          <a href="/en/contact" class="btn-primary">
            Contact me
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/banconl%C3%A9-akobi-a88940273" class="btn-ghost" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header gsap-reveal">
      <p class="label">From Lomé to Bucharest</p>
      <h2 class="section-title">{about.timeline_title}</h2>
    </div>
    <div class="timeline gsap-stagger">
      {about.timeline.map((item, i) => (
        <TimelineItem date={item.date} title={item.title} place={item.place} desc={item.desc} index={i} />
      ))}
    </div>
  </section>

  <section class="section values-section">
    <div class="section-header gsap-reveal">
      <p class="label">What guides me</p>
      <h2 class="section-title">{about.values_title}</h2>
    </div>
    <div class="values-grid gsap-stagger">
      {about.values.map(value => (
        <div class="value-card gsap-item">
          <div class="value-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              {value.icon === 'target' && <><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></>}
              {value.icon === 'search' && <><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></>}
              {value.icon === 'mic' && <><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></>}
            </svg>
          </div>
          <h3 class="value-title">{value.title}</h3>
          <p class="value-desc">{value.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header gsap-reveal">
      <p class="label">Recognition</p>
      <h2 class="section-title">{about.certifications_title}</h2>
    </div>
    <div class="certs-grid gsap-stagger">
      {about.certifications.map(cert => (
        <div class="cert-card gsap-item">
          <div class="cert-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="8" r="6"/>
              <path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
            </svg>
          </div>
          <span class="cert-name">{cert}</span>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { padding: clamp(8rem,12vw,12rem) clamp(1.5rem,5vw,4rem) clamp(2rem,4vw,4rem); border-bottom: 1px solid var(--border-subtle); background: var(--gradient-hero); }
  .page-hero-inner { max-width: 1400px; margin: 0 auto; }
  .page-title { font-size: clamp(2.5rem,6vw,5.5rem); font-style: italic; margin-top: 0.5rem; }
  .bio-section { border-bottom: 1px solid var(--border-subtle); }
  .bio-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 5rem; align-items: start; }
  .bio-photo { position: sticky; top: 6rem; }
  .photo-container { width: 100%; aspect-ratio: 5/6; overflow: hidden; border: 1px solid var(--border-subtle); background: var(--bg-elevated); }
  .profile-img { width: 100%; height: 100%; object-fit: cover; }
  .photo-placeholder { width:100%; height:100%; min-height:400px; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,var(--bg-elevated),var(--bg-secondary)); }
  .bio-text { padding-top: 1rem; }
  .bio-heading { font-size: clamp(1.8rem,3vw,2.5rem); font-style: normal; margin-bottom: 1.5rem; }
  .bio-paragraphs { display:flex; flex-direction:column; gap:1.25rem; margin-bottom:2.5rem; }
  .bio-para { font-size:1.0625rem; line-height:1.8; color:var(--text-secondary); }
  .bio-links { display:flex; align-items:center; gap:1.5rem; flex-wrap:wrap; }
  .btn-ghost { font-family:var(--font-sans); font-size:0.875rem; font-weight:500; color:var(--text-secondary); text-decoration:none; transition:color 0.3s ease; min-height:44px; display:inline-flex; align-items:center; }
  .btn-ghost:hover { color:var(--text-primary); }
  .timeline { max-width:700px; padding-top:1rem; }
  .section-header { margin-bottom:3rem; }
  .section-title { font-size:clamp(1.8rem,3.5vw,2.8rem); font-style:normal; margin-top:0.5rem; }
  .values-section { background:var(--bg-secondary); border-top:1px solid var(--border-subtle); border-bottom:1px solid var(--border-subtle); max-width:100%; }
  .values-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1px; border:1px solid var(--border-subtle); }
  .value-card { background:var(--bg-primary); padding:2.5rem 2rem; display:flex; flex-direction:column; gap:1rem; border-right:1px solid var(--border-subtle); transition:background 0.3s ease; }
  .value-card:last-child { border-right:none; }
  .value-card:hover { background:var(--bg-elevated); }
  .value-icon { color:var(--accent-gold); width:44px; height:44px; display:flex; align-items:center; justify-content:center; border:1px solid var(--border-subtle); }
  .value-title { font-family:var(--font-serif); font-size:1.2rem; font-style:normal; color:var(--text-primary); }
  .value-desc { font-size:0.9rem; line-height:1.7; }
  .certs-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; }
  .cert-card { background:var(--bg-secondary); border:1px solid var(--border-subtle); padding:1.25rem 1.5rem; display:flex; align-items:center; gap:1rem; transition:border-color 0.3s ease; }
  .cert-card:hover { border-color:var(--accent-gold); }
  .cert-icon { color:var(--accent-gold); flex-shrink:0; }
  .cert-name { font-size:0.875rem; color:var(--text-secondary); line-height:1.4; }
  @media (max-width:1024px) { .bio-grid { grid-template-columns:1fr; gap:3rem; } .bio-photo { position:static; max-width:350px; } .values-grid { grid-template-columns:1fr; } .value-card { border-right:none; border-bottom:1px solid var(--border-subtle); } .certs-grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:640px) { .certs-grid { grid-template-columns:1fr; } }
</style>
