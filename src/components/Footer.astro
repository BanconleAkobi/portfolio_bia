---
import { t, getLocalePath } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);

const navItems = [
  { href: getLocalePath(lang, '/'), label: tr.nav.home },
  { href: getLocalePath(lang, '/about'), label: tr.nav.about },
  { href: getLocalePath(lang, '/projects'), label: tr.nav.projects },
  { href: getLocalePath(lang, '/blog'), label: tr.nav.blog },
  { href: getLocalePath(lang, '/contact'), label: tr.nav.contact },
];
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <!-- Col 1: Nav -->
      <div class="footer-col">
        <p class="footer-col-title label">{tr.footer.nav_title}</p>
        <nav aria-label="Navigation footer">
          {navItems.map(item => (
            <a href={item.href} class="footer-link link-underline">{item.label}</a>
          ))}
        </nav>
      </div>

      <!-- Col 2: Contact -->
      <div class="footer-col">
        <p class="footer-col-title label">{tr.footer.contact_title}</p>
        <a href="mailto:ingenieurbanconle@gmail.com" class="footer-link link-underline">
          ingenieurbanconle@gmail.com
        </a>
        <a href="https://lanceos.eu" class="footer-link link-underline" target="_blank" rel="noopener">
          lanceos.eu
        </a>
        <p class="footer-location">Valenciennes / Versailles, France</p>
      </div>

      <!-- Col 3: Social -->
      <div class="footer-col">
        <p class="footer-col-title label">{tr.footer.social_title}</p>
        <a
          href="https://github.com/BanconleAkobi"
          class="footer-link link-underline"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub de Banconlé AKOBI"
        >
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/banconl%C3%A9-akobi-a88940273"
          class="footer-link link-underline"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn de Banconlé AKOBI"
        >
          LinkedIn
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">
        {tr.footer.copyright} — {tr.footer.tagline}
      </p>
      <a
        href="https://github.com/BanconleAkobi"
        class="footer-source mono"
        target="_blank"
        rel="noopener noreferrer"
      >
        &lt;/code&gt; sur GitHub
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-subtle);
    margin-top: 6rem;
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem clamp(1.5rem, 5vw, 4rem) 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-col-title {
    margin-bottom: 0.5rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.3s ease;
    width: fit-content;
  }

  .footer-link:hover {
    color: var(--text-primary);
  }

  .footer-location {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 2rem;
    border-top: 1px solid var(--border-subtle);
  }

  .footer-copyright {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .footer-source {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-source:hover {
    color: var(--accent-cyber);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
