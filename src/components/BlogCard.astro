---
interface Props {
  title: string;
  category: string;
  date: string;
  excerpt: string;
  slug: string;
  lang: 'fr' | 'en';
  featured?: boolean;
}

const { title, category, date, excerpt, slug, lang, featured } = Astro.props;
const href = `/${lang}/blog/${slug}`;
---

<article class={`blog-card gsap-item ${featured ? 'blog-card--featured' : ''}`}>
  <div class="blog-image gsap-clip">
    <div class="blog-placeholder" aria-label={`Image pour l'article: ${title}`}>
      <span class="blog-category-bg">{category}</span>
      <!-- TODO: remplacer par image réelle -->
    </div>
  </div>
  <div class="blog-content">
    <div class="blog-meta">
      <span class="blog-category label">{category}</span>
      <time class="blog-date mono" datetime={date}>{date}</time>
    </div>
    <h2 class="blog-title">
      <a href={href} class="blog-title-link">{title}</a>
    </h2>
    <p class="blog-excerpt">{excerpt}</p>
    <a href={href} class="blog-read-more">
      {lang === 'fr' ? 'Lire l\'article' : 'Read article'}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </a>
  </div>
</article>

<style>
  .blog-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .blog-card:hover {
    border-color: var(--accent-gold);
    transform: translateY(-4px);
  }

  .blog-card--featured {
    grid-column: 1 / -1;
    flex-direction: row;
  }

  .blog-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .blog-card--featured .blog-image {
    aspect-ratio: unset;
    width: 50%;
    flex-shrink: 0;
  }

  .blog-placeholder {
    width: 100%;
    height: 100%;
    min-height: 200px;
    background: linear-gradient(135deg, var(--bg-elevated), #0d1117);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .blog-category-bg {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-style: italic;
    color: var(--text-secondary);
    opacity: 0.15;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .blog-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .blog-card--featured .blog-content {
    padding: 2.5rem;
    justify-content: center;
  }

  .blog-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .blog-category {
    font-size: 0.7rem;
  }

  .blog-date {
    font-size: 0.7rem;
    color: var(--text-secondary);
  }

  .blog-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-style: normal;
    line-height: 1.3;
  }

  .blog-card--featured .blog-title {
    font-size: clamp(1.3rem, 2vw, 1.8rem);
  }

  .blog-title-link {
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .blog-title-link:hover {
    color: var(--accent-gold);
  }

  .blog-excerpt {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent-gold);
    text-decoration: none;
    transition: gap 0.3s ease;
    margin-top: auto;
    min-height: 44px;
  }

  .blog-read-more:hover {
    gap: 0.8rem;
  }

  @media (max-width: 768px) {
    .blog-card--featured {
      flex-direction: column;
    }

    .blog-card--featured .blog-image {
      width: 100%;
      aspect-ratio: 16 / 9;
    }
  }
</style>
