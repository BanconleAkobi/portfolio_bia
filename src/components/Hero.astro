---
import { t, getLocalePath } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---

<section class="hero" aria-label="Introduction">
  <!-- Background grid pattern -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <div class="hero-gradient"></div>
  </div>

  <!-- Social sidebar -->
  <aside class="social-sidebar" aria-label="Réseaux sociaux">
    <a
      href="https://github.com/BanconleAkobi"
      target="_blank"
      rel="noopener noreferrer"
      class="social-link"
      aria-label="GitHub"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
      </svg>
    </a>
    <a
      href="https://www.linkedin.com/in/banconl%C3%A9-akobi-a88940273"
      target="_blank"
      rel="noopener noreferrer"
      class="social-link"
      aria-label="LinkedIn"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
        <rect x="2" y="9" width="4" height="12"/>
        <circle cx="4" cy="4" r="2"/>
      </svg>
    </a>
    <a
      href="mailto:ingenieurbanconle@gmail.com"
      class="social-link"
      aria-label="Email"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
        <polyline points="22,6 12,13 2,6"/>
      </svg>
    </a>
    <div class="social-line" aria-hidden="true"></div>
  </aside>

  <!-- Main hero content -->
  <div class="hero-content">
    <div class="hero-label label" id="hero-label">
      <span class="mono">&gt;_</span> {lang === 'fr' ? 'Ingénieur / Bâtisseur' : 'Engineer / Builder'}
    </div>

    <h1 id="hero-title" class="hero-title" aria-label={tr.hero.name}>
      {tr.hero.name}
    </h1>

    <p id="hero-subtitle" class="hero-subtitle" style="opacity:0">
      {tr.hero.subtitle}
    </p>

    <p id="hero-tagline" class="hero-tagline" style="opacity:0">
      {tr.hero.tagline}
    </p>

    <div id="hero-cta" class="hero-cta" style="opacity:0">
      <a href={getLocalePath(lang, '/about')} class="btn-primary">
        {tr.hero.cta}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
      <a href={getLocalePath(lang, '/projects')} class="btn-ghost">
        {lang === 'fr' ? 'Voir les projets' : 'View projects'}
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator" id="scroll-indicator" aria-hidden="true">
      <span class="scroll-text">{tr.hero.scroll}</span>
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--gradient-hero);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border-subtle) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-subtle) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.3;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
  }

  .hero-gradient {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(transparent, var(--bg-primary));
  }

  .social-sidebar {
    position: fixed;
    left: clamp(1rem, 3vw, 2.5rem);
    bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    z-index: 100;
  }

  .social-link {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.3s ease, transform 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
  }

  .social-link:hover {
    color: var(--accent-gold);
    transform: translateY(-2px);
  }

  .social-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(var(--border-subtle), transparent);
    margin-top: 0.5rem;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    padding: clamp(6rem, 10vw, 10rem) clamp(1.5rem, 5vw, 5rem) clamp(4rem, 6vw, 6rem);
    padding-left: calc(clamp(1.5rem, 5vw, 5rem) + 60px);
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
  }

  .hero-label {
    margin-bottom: 1.5rem;
    opacity: 0;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 7rem);
    font-style: italic;
    font-family: var(--font-serif);
    color: var(--text-primary);
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .hero-subtitle {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(0.875rem, 1.5vw, 1.1rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent-gold);
    margin-bottom: 2rem;
  }

  .hero-tagline {
    font-size: clamp(1rem, 1.5vw, 1.1rem);
    color: var(--text-secondary);
    max-width: 560px;
    line-height: 1.8;
    margin-bottom: 3rem;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn-ghost {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 0.3s ease;
    position: relative;
  }

  .btn-ghost::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--text-primary);
    transition: width 0.3s ease;
  }

  .btn-ghost:hover {
    color: var(--text-primary);
  }

  .btn-ghost:hover::after {
    width: 100%;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    right: clamp(1.5rem, 5vw, 4rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    opacity: 0;
  }

  .scroll-text {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-secondary);
    writing-mode: vertical-rl;
  }

  .scroll-line {
    width: 1px;
    height: 50px;
    background: linear-gradient(var(--accent-gold), transparent);
    animation: scrollDown 2s ease-in-out infinite;
  }

  @keyframes scrollDown {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }

  @media (max-width: 768px) {
    .social-sidebar {
      display: none;
    }

    .hero-content {
      padding-left: clamp(1.5rem, 5vw, 3rem);
    }

    .scroll-indicator {
      right: 1.5rem;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gsap === 'undefined') return;

    const tl = gsap.timeline({ delay: 0.3 });

    // Label
    tl.fromTo('#hero-label',
      { opacity: 0, x: -20 },
      { opacity: 1, x: 0, duration: 0.6, ease: 'power3.out' }
    );

    // Title — char by char
    const title = document.querySelector('#hero-title');
    if (title) {
      const text = title.textContent || '';
      title.innerHTML = text.split('').map(char =>
        char === ' ' ? '<span style="display:inline-block;opacity:0">&nbsp;</span>' :
        `<span style="display:inline-block;opacity:0">${char}</span>`
      ).join('');

      tl.fromTo('#hero-title span',
        { opacity: 0, y: 40, rotateX: -30 },
        {
          opacity: 1,
          y: 0,
          rotateX: 0,
          duration: 0.6,
          stagger: 0.04,
          ease: 'back.out(1.2)',
        },
        '-=0.2'
      );
    }

    tl.fromTo('#hero-subtitle',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' },
      '-=0.1'
    );

    tl.fromTo('#hero-tagline',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' },
      '-=0.4'
    );

    tl.fromTo('#hero-cta',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' },
      '-=0.4'
    );

    tl.fromTo('#scroll-indicator',
      { opacity: 0 },
      { opacity: 1, duration: 0.5, ease: 'power2.out' },
      '-=0.2'
    );
  });
</script>
